# ──────────── Backend Environment Variables ────────────

# MongoDB connection string (use MongoDB Atlas for production)
MONGO_URI=mongodb://localhost:27017/taskmanager

# JWT secret key — use a long, random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here

# Server port (Render/Railway will set this automatically)
PORT=5000

# Frontend URL for CORS (set to your Vercel deployment URL in production)
CLIENT_URL=http://localhost:3000

# Node environment
NODE_ENV=development
